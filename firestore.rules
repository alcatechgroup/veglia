rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function myCompany() {
      return request.auth.token.company_id;
    }

    function myRole() {
      return request.auth.token.role;
    }

    function isAdmin() {
      return isAuthenticated() && myRole() == 'admin';
    }

    function isRH() {
      return isAuthenticated() && (myRole() == 'admin' || myRole() == 'rh' || myRole() == 'admin_rh' || myRole() == 'rh_filial');
    }

    function belongsToCompany(company_id) {
      return isAuthenticated() && myCompany() == company_id;
    }

    // ── Companies ─────────────────────────────────────────────────────────────
    match /companies/{company_id} {
      allow read: if isAdmin()
                  || belongsToCompany(company_id)
                  || (isAuthenticated()
                      && resource.data.parent_id != null
                      && resource.data.parent_id == myCompany()
                      && (myRole() == 'admin_rh' || myRole() == 'rh'));
      allow create: if false; // apenas via Cloud Function createCompany/createBranch
      allow update: if isAdmin() && belongsToCompany(company_id);
      allow delete: if false;
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if request.auth.uid == uid
                  || (isRH() && resource.data.company_id == myCompany());
      // Permite create para o fluxo de aceite de convite (client-side no MVP)
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if false;
      allow delete: if false;
    }

    // ── Invites ───────────────────────────────────────────────────────────────
    match /invites/{invite_id} {
      // Qualquer um pode ler (o token já é o segredo — UUID não adivinhável)
      allow read: if true;
      allow create: if isRH()
                    && request.resource.data.company_id == myCompany();
      // Colaborador atualiza used_at no aceite do convite
      // Restringe a apenas o destinatário do convite; bloqueia alteração de company_id e role
      allow update: if isAuthenticated()
                    && resource.data.email == request.auth.token.email
                    && !('company_id' in request.resource.data.diff(resource.data).affectedKeys())
                    && !('role' in request.resource.data.diff(resource.data).affectedKeys());
      allow delete: if isAdmin() && resource.data.company_id == myCompany();
    }

    // ── Enrollments (flat: documentId = uid_courseId) ─────────────────────────
    // Colaborador escreve o próprio progresso.
    // RH/Admin da mesma empresa pode ler para relatórios.
    //
    // NOTA: resource.data não está disponível em queries de coleção (where()),
    // apenas em leituras de documento individual. Para que a query do DashboardRH
    // (where("company_id", "==", companyId)) não seja bloqueada com permission-denied,
    // a regra de leitura usa request.auth.token — disponível tanto em leituras
    // individuais quanto em queries. A segurança de isolamento por empresa é
    // garantida pelo custom claim company_id + pela própria query filtrada.
    match /enrollments/{enrollment_id} {
      allow read: if isAuthenticated()
                  && (
                    // próprio colaborador — leitura individual pelo padrão uid_courseId
                    enrollment_id.matches(request.auth.uid + "_.*")
                    // ou RH/Admin da mesma empresa — verifica company_id para isolamento
                    || (isRH() && resource.data.company_id == myCompany())
                  );
      allow create: if isAuthenticated()
                    && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated()
                    && resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    // ── Certificates ─────────────────────────────────────────────────────────
    // Escrita exclusiva via Cloud Function (Admin SDK ignora estas rules).
    // Client nunca cria ou altera certificados — evita adulteração.
    match /certificates/{certificate_id} {
      allow read: if isAuthenticated()
                  && (
                    resource.data.uid == request.auth.uid
                    || (isRH() && resource.data.company_id == myCompany())
                  );
      allow create, update: if false;
      allow delete: if false;
    }

    // ── Diagnostic Results (freemium — visitante autenticado pode criar) ─────────
    // uid no payload deve ser o do próprio usuário — bloqueia escrita cross-user.
    match /diagnostic_results/{id} {
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    // ── Config (video IDs e configurações da plataforma) ──────────────────────
    // Qualquer autenticado pode ler (necessário para useVideoIds nas trilhas).
    // Apenas admin pode escrever (protege contra adulteração de conteúdo).
    match /config/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── OneDrive Docs (sync via Power Automate) ───────────────────────────────
    // Power Automate autentica anonimamente (Firebase anon auth) para gravar.
    // Apenas usuários reais (com email) podem ler — os 3 sócios.
    match /onedrive_docs/{docId} {
      allow create: if request.auth != null;
      allow read:   if request.auth != null && request.auth.token.email != null;
      allow update, delete: if false;
    }

    // ── Leads (capturados pelo chat Vela e formulário da landing page) ────────
    // Leitura e escrita de status/notas: apenas admin.
    // Criação via Cloud Function usa Admin SDK (ignora estas rules).
    // allow create: if true — fallback caso o client precise criar diretamente
    // (ex: se Cloud Function estiver indisponível), mas fluxo normal é via CF.
    match /leads/{leadId} {
      allow read, write: if isAdmin();
      allow create: if true;
    }

    // ── Health Passports ──────────────────────────────────────────────────────
    // Colaborador lê/escreve o próprio passaporte vacinal.
    // RH da mesma empresa pode ler (relatórios de cobertura).
    match /health_passports/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isRH());
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // ── Video Progress ────────────────────────────────────────────────────────
    // Colaborador escreve/lê o próprio progresso de vídeo.
    // Nota: o player atual usa enrollments/{uid_courseId}; esta coleção é
    // reservada para tracking granular futuro (por segmento/timestamp).
    match /video_progress/{docId} {
      allow read, write: if isAuthenticated();
    }

    // ── Compliance Scores ─────────────────────────────────────────────────────
    // Calculado pela Cloud Function — client nunca escreve.
    // RH lê apenas o score da própria empresa.
    match /compliance_scores/{companyId} {
      allow read: if isRH() && myCompany() == companyId;
      allow write: if false; // somente Cloud Function via Admin SDK
    }

    // ── Vaccination Records ───────────────────────────────────────────────────
    // Colaborador cria/lê os próprios registros. Nenhuma alteração ou deleção.
    // RH da mesma empresa pode ler para relatórios.
    match /vaccination_records/{recordId} {
      allow read: if isAuthenticated() && (
        resource.data.uid == request.auth.uid || isRH()
      );
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Company Certificates ──────────────────────────────────────────────────
    // Gerado pela Cloud Function após conclusão do curso.
    // RH lê os certificados da própria empresa.
    match /company_certificates/{docId} {
      allow read: if isRH();
      allow write: if false; // somente Cloud Function via Admin SDK
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    // Usuário lê e pode marcar como lida (campo 'read' apenas).
    // Criação e deleção: exclusivo Cloud Function.
    match /notifications/{notifId} {
      allow read: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.user_id == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create, delete: if false; // somente Cloud Function
    }

    // ── User Points ───────────────────────────────────────────────────────────
    // Gamificação futura (F09). Escrita exclusiva via Cloud Function.
    match /user_points/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if false; // somente Cloud Function via Admin SDK
    }

    // ── AI Chats ──────────────────────────────────────────────────────────────
    // Usuário lê/escreve apenas o próprio histórico de chat.
    // Subcoleção messages segue o mesmo isolamento do documento pai.
    match /ai_chats/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      match /messages/{msgId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    // ── Audit Events ──────────────────────────────────────────────────────────
    // Escrito exclusivamente pela Cloud Function (Admin SDK).
    // Somente admin interno pode ler — auditoria de segurança.
    match /audit_events/{eventId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── Vela Config (script do chat) ─────────────────────────────────────────
    // Leitura pública (landing.html lê sem autenticação).
    // Escrita exclusiva do admin interno.
    match /vela_config/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Import Batches ────────────────────────────────────────────────────────
    // Criado exclusivamente via Cloud Function importEmployees.
    // RH lê apenas batches da própria empresa.
    match /import_batches/{batchId} {
      allow read: if isRH() && resource.data.company_id == myCompany();
      allow write: if false; // somente Cloud Function
    }
  }
}
